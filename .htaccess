RewriteEngine On

# Redirect to HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Allow direct access to existing files and directories
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Handle API requests - ensure .php extension works
RewriteRule ^api/(.*)$ api/$1 [L]

# Fallback to index.php for SPA-style routing.
# Skip asset paths (js/css/images/fonts) so missing asset files 404 cleanly
# instead of being silently rewritten to index.php -> login.html (which the
# browser then refuses to execute as JavaScript due to MIME type mismatch).
RewriteCond %{REQUEST_URI} !\.(js|css|map|jpg|jpeg|png|gif|svg|ico|webp|woff|woff2|ttf|eot|otf|pdf|mp4|webm|ogg|wav|mp3)$
RewriteRule ^ index.php [L]

# Security headers
<IfModule mod_headers.c>
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-Content-Type-Options "nosniff"
    Header set X-XSS-Protection "1; mode=block"
</IfModule>

# Deny access to sensitive files
<FilesMatch "\.(pem|sh|md)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Deny access to hidden files
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>
