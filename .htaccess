RewriteEngine On

# CRITICAL: Pass the Authorization request header to PHP-FPM.
#
# PHP-FPM (which InfinityFree uses) does NOT forward the Authorization
# request header to PHP by default — it just disappears, so
# $_SERVER['HTTP_AUTHORIZATION'] is never populated and every JWT-authenticated
# API call returns 401. The fix: copy the incoming Authorization header into
# the HTTP_AUTHORIZATION env var via three different mechanisms (mod_setenvif,
# mod_headers, and mod_rewrite), any one of which should be enough on
# InfinityFree's Apache + PHP-FPM setup.
#
# This must come before any other RewriteRule that might handle the request
# so the env var is set before the PHP handler runs.

# Method 1: mod_setenvif (most reliable, works on virtually all Apache configs)
<IfModule mod_setenvif.c>
    SetEnvIfNoCase ^Authorization$ "(.+)" HTTP_AUTHORIZATION=$1
</IfModule>

# Method 2: mod_headers
<IfModule mod_headers.c>
    RequestHeader set Authorization "%{Authorization}e" env=HTTP_AUTHORIZATION
</IfModule>

# Method 3: mod_rewrite (as a final fallback)
<IfModule mod_rewrite.c>
    RewriteCond %{HTTP:Authorization} ^(.+)$
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
</IfModule>

# Redirect to HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Allow direct access to existing files and directories
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Handle API requests - ensure .php extension works
RewriteRule ^api/(.*)$ api/$1 [L]

# Fallback to index.php for SPA-style routing.
# Skip asset paths (js/css/images/fonts) so missing asset files 404 cleanly
# instead of being silently rewritten to index.php -> login.html (which the
# browser then refuses to execute as JavaScript due to MIME type mismatch).
RewriteCond %{REQUEST_URI} !\.(js|css|map|jpg|jpeg|png|gif|svg|ico|webp|woff|woff2|ttf|eot|otf|pdf|mp4|webm|ogg|wav|mp3)$
RewriteRule ^ index.php [L]

# Security headers
<IfModule mod_headers.c>
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-Content-Type-Options "nosniff"
    Header set X-XSS-Protection "1; mode=block"
</IfModule>

# Deny access to sensitive files
<FilesMatch "\.(pem|sh|md)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Deny access to hidden files
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>
