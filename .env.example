# Highland Fresh local environment variables
# Copy to .env and replace values.

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=highland_fresh
DB_USERNAME=root
DB_PASSWORD=

# SMTP (Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_ENCRYPTION=tls
SMTP_USERNAME=ragasibrian2@gmail.com
SMTP_FROM_EMAIL=ragasibrian2@gmail.com
SMTP_FROM_NAME=Highland Fresh Dairy
# Use a 16-character Gmail App Password (not your normal Gmail password)
SMTP_PASSWORD=REPLACE_WITH_GMAIL_APP_PASSWORD

# App URL
APP_URL=http://localhost/HighlandFreshAppV4
