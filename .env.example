# Highland Fresh environment variables
# Copy this file to `.env` and replace values for your deployment target.
# The default values below assume XAMPP / local development.
# Items marked [INFINITYFREE] need to be overridden when deploying to InfinityFree.

# ===== Database =====
# [INFINITYFREE] Replace these 4 with values from your InfinityFree control panel
#                (cPanel > "MySQL Databases" section):
#   DB_HOST=sqlNNN.infinityfree.com      (e.g. sql200.epizy.com — your DB host)
#   DB_NAME=epZZ_NNNNNN_highland_fresh   (whatever DB name you created)
#   DB_USERNAME=epZZ_NNNNNN              (NOT "root" — InfinityFree uses a prefixed user)
#   DB_PASSWORD=<your InfinityFree DB password>
DB_HOST=localhost
DB_PORT=3306
DB_NAME=highland_fresh
DB_USERNAME=root
DB_PASSWORD=

# ===== Application URL =====
# [INFINITYFREE] APP_URL=https://yoursite.infinityfreeapp.com
#   (omit the /HighlandFreshAppV4 subfolder ONLY if you deploy at htdocs/ root;
#    otherwise include the subfolder in the path)
APP_URL=http://localhost/HighlandFreshAppV4

# ===== SMTP / Email =====
# WARNING: InfinityFree BLOCKS outbound SMTP (ports 25/465/587) on the free tier.
#   The mailer at api/config/mailer.php will fail with "SMTP connection failed"
#   until you either:
#     (a) switch to an HTTPS email API (Resend / Brevo / SendGrid) and rewrite mailer.php, or
#     (b) drop email features (invite / password reset) and surface tokens in admin UI.
#   The defaults below only work where outbound SMTP is allowed (XAMPP, paid host).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_ENCRYPTION=tls
SMTP_USERNAME=ragasibrian2@gmail.com
SMTP_FROM_EMAIL=ragasibran2@gmail.com
SMTP_FROM_NAME=Highland Fresh Dairy
# Use a 16-character Gmail App Password (not your normal Gmail password)
SMTP_PASSWORD=REPLACE_WITH_GMAIL_APP_PASSWORD

# ===== Audit log integrity chain (optional) =====
# Falls back to JWT_SECRET if unset. Set independently if you want the audit chain
# keyed separately from session tokens.
# AUDIT_LOG_SECRET=
